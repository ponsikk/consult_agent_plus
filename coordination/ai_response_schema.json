{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "VisionAnalysisResponse",
  "type": "object",
  "properties": {
    "defects": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "defect_type": {
            "type": "string",
            "description": "Code of the defect from defect_catalog.json. MANDATORY field."
          },
          "name": {
            "type": "string",
            "description": "Short name of the defect"
          },
          "bbox": {
            "type": "object",
            "properties": {
              "x": { "type": "number", "minimum": 0, "maximum": 1 },
              "y": { "type": "number", "minimum": 0, "maximum": 1 },
              "w": { "type": "number", "minimum": 0, "maximum": 1 },
              "h": { "type": "number", "minimum": 0, "maximum": 1 }
            },
            "required": ["x", "y", "w", "h"],
            "description": "Normalized bounding box (0.0 to 1.0)"
          },
          "criticality": {
            "type": "string",
            "enum": ["critical", "significant", "minor"],
            "description": "Severity of the defect"
          },
          "description": {
            "type": "string",
            "description": "Specific observation from the image"
          },
          "consequences": {
            "type": "string",
            "description": "Typical consequences of this defect"
          },
          "norm_references": {
            "type": "array",
            "items": { "type": "string" },
            "description": "References to standards (SP, SNiP, GOST)"
          },
          "recommendations": {
            "type": "string",
            "description": "Typical recommendations for fixing"
          }
        },
        "required": ["defect_type", "name", "bbox", "criticality", "description", "consequences", "norm_references", "recommendations"]
      }
    },
    "overall_status": {
      "type": "string",
      "enum": ["satisfactory", "unsatisfactory", "critical"],
      "description": "Overall condition of the element shown in the photo"
    },
    "summary": {
      "type": "string",
      "description": "Brief expert summary of the inspection"
    }
  },
  "required": ["defects", "overall_status", "summary"]
}
